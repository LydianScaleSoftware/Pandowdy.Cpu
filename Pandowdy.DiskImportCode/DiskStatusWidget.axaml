<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Pandowdy.UI.ViewModels"
             x:Class="Pandowdy.UI.Controls.DiskStatusWidget"
             x:DataType="vm:DiskStatusWidgetViewModel">

    <Border BorderBrush="#404040" 
            BorderThickness="1" 
            Background="#202020"
            CornerRadius="4"
            Padding="8"
            Margin="0,0,0,4">
        
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding DiskId}"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="#00FF00"
                       HorizontalAlignment="Center" />

            <TextBlock Text="{Binding Filename}"
                       FontSize="11"
                       Foreground="{Binding FilenameForeground}"
                       HorizontalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="150"
                       ToolTip.Tip="{Binding DiskImagePathTooltip}" />

            <TextBlock Text="{Binding TrackSectorText}"
                       FontSize="11"
                       FontFamily="Consolas"
                       Foreground="{Binding TrackSectorForeground}"
                       HorizontalAlignment="Center" />

            <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0"
                           Text="{Binding PhaseText}"
                           FontSize="11"
                           FontFamily="Consolas"
                           Foreground="#FFD700"
                           HorizontalAlignment="Left"
                           Margin="0,0,8,0" />

                <TextBlock Grid.Column="1"
                           Text="{Binding MotorText}"
                           FontSize="11"
                           FontFamily="Consolas"
                           Foreground="#00FFFF"
                           HorizontalAlignment="Right" />
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
