# DocFX Documentation
###################

# Generated site output (HTML files)
docfx_project/_site/
docs/_site/

# Generated API YAML files (regenerated from source code)
docfx_project/api/*.yml
docfx_project/api/.manifest
docs/api/

# Build artifacts
docfx_project/obj/
docfx_project/.manifest
docs/obj/
docs/.manifest

# Log files
docfx_project/docfx.log
docs/docfx.log

# XML documentation (regenerated from source)
**/bin/**/*.xml
**/obj/**/*.xml

# Keep embedded resources XML intact
!**/Resources/**/*.xml

*.ts
