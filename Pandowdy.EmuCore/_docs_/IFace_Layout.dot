digraph PandowdyEmuCore_Interfaces {
    // Graph styling - interface-focused view
    rankdir=TB;
    node [shape=ellipse, style=filled, fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];
    compound=true;
    nodesep=0.4;
    ranksep=0.8;
    
    // Color scheme
    // lightgreen = Interface
    // lightblue = Concrete (no interface available)
    // wheat = External library
    
    // ========================================
    // TIER 1: ORCHESTRATION (CONCRETE - NO INTERFACE)
    // ========================================
    
    subgraph cluster_orchestration {
        label="Orchestration";
        style=filled;
        color=lightsteelblue;
        
        VA2M [fillcolor=lightblue, shape=box, label="VA2M\n(no interface)"];
    }
    
    // ========================================
    // TIER 2: BUS + CPU
    // ========================================
    
    subgraph cluster_bus_cpu {
        label="Bus & CPU";
        style=filled;
        color=lightcoral;
        
        IAppleIIBus [fillcolor=lightgreen, label="IAppleIIBus"];
        ICpu [fillcolor=lightgreen, label="ICpu"];
        ISystemIoHandler [fillcolor=lightgreen, label="ISystemIoHandler"];
        
        CPU [fillcolor=wheat, shape=box, label="Emulator.CPU\n(6502.NET)\nexternal"];
    }
    
    // ========================================
    // TIER 3: INPUT + STATE
    // ========================================
    
    subgraph cluster_input {
        label="Input";
        style=filled;
        color=lightgoldenrodyellow;
        
        IKeyboardSetter [fillcolor=lightgreen, label="IKeyboardSetter"];
        IKeyboardReader [fillcolor=lightgreen, label="IKeyboardReader"];
        IGameControllerStatus [fillcolor=lightgreen, label="IGameControllerStatus"];
    }
    
    subgraph cluster_state {
        label="State & Status";
        style=filled;
        color=lavender;
        
        ISystemStatusProvider [fillcolor=lightgreen, label="ISystemStatusProvider\n(read-only)"];
        ISystemStatusMutator [fillcolor=lightgreen, label="ISystemStatusMutator\n(extends ISystemStatusProvider)"];
        IEmulatorState [fillcolor=lightgreen, label="IEmulatorState"];
        
        SoftSwitches [fillcolor=lightblue, shape=box, label="SoftSwitches\n(no interface)"];
    }
    
    // ========================================
    // TIER 4: MEMORY SUBSYSTEM
    // ========================================
    
    subgraph cluster_memory {
        label="Memory Subsystem";
        style=filled;
        color=lightcyan;
        
        // Router interfaces
        IMemory [fillcolor=lightgreen, label="IMemory"];
        IDirectMemoryPoolReader [fillcolor=lightgreen, label="IDirectMemoryPoolReader"];
        
        // Memory region interfaces
        ISystemRamSelector [fillcolor=lightgreen, label="ISystemRamSelector\n$0000-$BFFF"];
        ISlots [fillcolor=lightgreen, label="ISlots\n$C090-$CFFF"];
        ILanguageCard [fillcolor=lightgreen, label="ILanguageCard\n$D000-$FFFF"];
        
        // Supporting interfaces
        ISystemRam [fillcolor=lightgreen, label="ISystemRam", penwidth=3, style="filled,bold"];
        ISystemRomProvider [fillcolor=lightgreen, label="ISystemRomProvider\n(shared by Slots & LangCard)", penwidth=2];
        IFloatingBusProvider [fillcolor=lightgreen, label="IFloatingBusProvider"];
        
        // Card system
        ICard [fillcolor=lightgreen, label="ICard", penwidth=3, style="filled,bold"];
        ICardFactory [fillcolor=lightgreen, label="ICardFactory"];
    }
    
    // ========================================
    // TIER 5: RENDERING
    // ========================================
    
    subgraph cluster_rendering {
        label="Rendering";
        style=filled;
        color=mistyrose;
        
        IFrameGenerator [fillcolor=lightgreen, label="IFrameGenerator"];
        IFrameProvider [fillcolor=lightgreen, label="IFrameProvider"];
        IDisplayBitmapRenderer [fillcolor=lightgreen, label="IDisplayBitmapRenderer"];
        ICharacterRomProvider [fillcolor=lightgreen, label="ICharacterRomProvider"];
        
        RenderingService [fillcolor=lightblue, shape=box, label="RenderingService\n(no interface)"];
        VideoMemorySnapshotPool [fillcolor=lightblue, shape=box, label="VideoMemorySnapshotPool\n(no interface)"];
    }
    
    // ========================================
    // INTERFACE RELATIONSHIPS
    // ========================================
    
    // Inheritance
    ISystemStatusMutator -> ISystemStatusProvider [label="extends", style=dashed, color=green, penwidth=2];
    
    // ========================================
    // KEY DEPENDENCIES
    // ========================================
    
    // VA2M orchestration (concrete class dependencies)
    VA2M -> IEmulatorState [label="publishes", color=red];
    VA2M -> IFrameProvider [label="uses", color=red];
    VA2M -> ISystemStatusMutator [label="mutates", color=red, penwidth=2];
    VA2M -> IAppleIIBus [label="orchestrates", color=red, penwidth=2];
    VA2M -> IMemory [label="owns", color=red];
    VA2M -> IFrameGenerator [label="triggers", color=red];
    VA2M -> RenderingService [label="coordinates", color=red];
    VA2M -> VideoMemorySnapshotPool [label="pools", color=red];
    VA2M -> IKeyboardSetter [label="injects", color=red];
    VA2M -> IGameControllerStatus [label="delegates", color=red];
    
    // IAppleIIBus (VA2MBus) routing
    IAppleIIBus -> IMemory [label="routes $C090+", color=red, penwidth=2];
    IAppleIIBus -> ICpu [label="executes", color=red, penwidth=2];
    IAppleIIBus -> ISystemIoHandler [label="routes $C000", color=red, penwidth=2];
    
    // ISystemIoHandler coordination
    ISystemIoHandler -> SoftSwitches [label="manages", color=red, penwidth=2];
    ISystemIoHandler -> IKeyboardReader [label="reads", color=red];
    ISystemIoHandler -> IGameControllerStatus [label="reads", color=red];
    
    // ICpu wraps external CPU
    ICpu -> CPU [label="wraps", color=purple, penwidth=2];
    
    // IMemory (AddressSpaceController) routing
    IMemory -> ISystemRamSelector [label="$0000-$BFFF", color=red, penwidth=3];
    IMemory -> ISlots [label="$C090-$CFFF", color=red, penwidth=3];
    IMemory -> ILanguageCard [label="$D000-$FFFF", color=red, penwidth=3];
    
    // ISlots dependencies
    ISlots -> ICardFactory [label="creates", color=red];
    ISlots -> ISystemRomProvider [label="ROM", color=purple, penwidth=3, style=bold];
    ISlots -> IFloatingBusProvider [label="unmapped", color=red];
    ISlots -> ISystemStatusProvider [label="observes", color=red];
    ISlots -> ICard [label="manages[]", color=red, penwidth=3, style=bold];
    
    // ILanguageCard dependencies
    ILanguageCard -> ISystemRam [label="banks[2x16K]", color=red, penwidth=3, style=bold];
    ILanguageCard -> ISystemRomProvider [label="ROM", color=purple, penwidth=3, style=bold];
    ILanguageCard -> IFloatingBusProvider [label="unmapped", color=red];
    ILanguageCard -> ISystemStatusProvider [label="observes", color=red];
    
    // ISystemRamSelector dependencies
    ISystemRamSelector -> ISystemRam [label="switches[2x48K]", color=red, penwidth=3, style=bold];
    ISystemRamSelector -> IFloatingBusProvider [label="unmapped", color=red];
    ISystemRamSelector -> ISystemStatusProvider [label="observes", color=red];
    
    // IFrameGenerator rendering
    IFrameGenerator -> IFrameProvider [label="writes", color=red];
    IFrameGenerator -> IDisplayBitmapRenderer [label="renders", color=red, penwidth=2];
    IFrameGenerator -> IDirectMemoryPoolReader [label="reads RAM", color=red];
    IFrameGenerator -> ISystemStatusProvider [label="observes", color=red];
    
    // IDisplayBitmapRenderer dependencies
    IDisplayBitmapRenderer -> ICharacterRomProvider [label="reads chars", color=red, penwidth=2];
    
    // SoftSwitches (concrete - no interface)
    SoftSwitches -> ISystemStatusMutator [label="mutates", color=red, penwidth=3];
    SoftSwitches -> ISystemStatusProvider [label="reads", color=red];
    
    // ISystemStatusProvider event source
    ISystemStatusProvider -> IGameControllerStatus [label="observes", color=red, penwidth=2];
    
    // RenderingService (concrete - no interface)
    RenderingService -> VideoMemorySnapshotPool [label="pools", color=red];
    RenderingService -> IFrameGenerator [label="generates", color=red];
}
