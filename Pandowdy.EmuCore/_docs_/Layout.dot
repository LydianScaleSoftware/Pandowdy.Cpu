digraph PandowdyEmuCore {
    // Graph styling - optimized for compact vertical layout
    rankdir=TB;
    node [shape=rectangle, style=filled, fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];
    compound=true;
    nodesep=0.3;
    ranksep=0.8;
    
    // ========================================
    // TIER 1: ORCHESTRATION LAYER (TOP)
    // ========================================
    
    subgraph cluster_orchestration {
        label="Orchestration Layer";
        style=filled;
        color=lightsteelblue;
        
        VA2M [fillcolor=lightblue, label="VA2M\n(Singleton)\nOrchestrator"];
    }
    
    // ========================================
    // TIER 2: BUS + CPU (SIDE BY SIDE)
    // ========================================
    
    subgraph cluster_cpu {
        label="CPU Subsystem";
        style=filled;
        color=lightsalmon;
        
        CPU [fillcolor=wheat, label="Emulator.CPU\n(6502.NET)"];
        ICpu [fillcolor=lightgreen, shape=ellipse, label="ICpu"];
        CPUAdapter [fillcolor=lightblue, label="CPUAdapter\nAdapter"];
    }
    
    subgraph cluster_bus {
        label="Bus Subsystem";
        style=filled;
        color=lightcoral;
        
        IAppleIIBus [fillcolor=lightgreen, shape=ellipse, label="IAppleIIBus"];
        VA2MBus [fillcolor=lightblue, label="VA2MBus\nRouter\n$C000-$C08F"];
        
        ISystemIoHandler [fillcolor=lightgreen, shape=ellipse, label="ISystemIoHandler"];
        SystemIoHandler [fillcolor=lightblue, label="SystemIoHandler\nI/O $C000-$C08F"];
    }
    
    // Force CPU and Bus to same rank
    {rank=same; cluster_cpu; cluster_bus;}
    
    // ========================================
    // TIER 3: INPUT + STATE (SIDE BY SIDE)
    // ========================================
    
    subgraph cluster_input {
        label="Input Subsystem";
        style=filled;
        color=lightgoldenrodyellow;
        
        IKeyboardSetter [fillcolor=lightgreen, shape=ellipse, label="IKeyboardSetter"];
        IKeyboardReader [fillcolor=lightgreen, shape=ellipse, label="IKeyboardReader"];
        SingularKeyHandler [fillcolor=lightblue, label="SingularKeyHandler"];
        
        IGameControllerStatus [fillcolor=lightgreen, shape=ellipse, label="IGameControllerStatus"];
        SimpleGameController [fillcolor=lightblue, label="SimpleGameController"];
    }
    
    subgraph cluster_state {
        label="State & Status Subsystem";
        style=filled;
        color=lavender;
        
        SystemStatusProvider [fillcolor=lightblue, label="SystemStatusProvider\nObservable"];
        ISystemStatusProvider [fillcolor=lightgreen, shape=ellipse, label="ISystemStatusProvider"];
        ISystemStatusMutator [fillcolor=lightgreen, shape=ellipse, label="ISystemStatusMutator"];
        
        IEmulatorState [fillcolor=lightgreen, shape=ellipse, label="IEmulatorState"];
        EmulatorStateProvider [fillcolor=lightblue, label="EmulatorStateProvider"];
        
        SoftSwitches [fillcolor=lightblue, label="SoftSwitches"];
    }
    
    // Force Input and State to same rank
    {rank=same; cluster_input; cluster_state;}
    
    // ========================================
    // TIER 4: MEMORY SUBSYSTEM
    // ========================================
    
    subgraph cluster_memory_main {
        label="Memory Subsystem (Refactored)";
        style=filled;
        color=lightcyan;
        
        AddressSpaceController [fillcolor=lightblue, label="AddressSpaceController\nPure Router\n~200 lines", penwidth=3];
        IMemory [fillcolor=lightgreen, shape=ellipse, label="IMemory"];
        IDirectMemoryPoolReader [fillcolor=lightgreen, shape=ellipse, label="IDirectMemoryPoolReader"];
        
        subgraph cluster_ram_selector {
            label="RAM $0000-$BFFF";
            style=filled;
            color=paleturquoise;
            
            ISystemRamSelector [fillcolor=lightgreen, shape=ellipse, label="ISystemRamSelector"];
            SystemRamSelector [fillcolor=lightblue, label="SystemRamSelector\nMain/Aux"];
        }
        
        subgraph cluster_slots {
            label="Slots $C090-$CFFF";
            style=filled;
            color=paleturquoise;
            
            ISlots [fillcolor=lightgreen, shape=ellipse, label="ISlots"];
            Slots [fillcolor=lightblue, label="Slots\nCard Mgr"];
            
            ICard [fillcolor=lightgreen, shape=ellipse, label="ICard"];
            NullCard [fillcolor=lightyellow, label="NullCard"];
            ICardFactory [fillcolor=lightgreen, shape=ellipse, label="ICardFactory"];
        }
        
        subgraph cluster_language_card {
            label="LangCard $D000-$FFFF";
            style=filled;
            color=paleturquoise;
            
            ILanguageCard [fillcolor=lightgreen, shape=ellipse, label="ILanguageCard"];
            LanguageCard [fillcolor=lightblue, label="LanguageCard\nBanked"];
        }
        
        subgraph cluster_system_ram {
            label="System RAM";
            style=filled;
            color=paleturquoise;
            
            ISystemRam [fillcolor=lightgreen, shape=ellipse, label="ISystemRam"];
            MemoryBlock_16K [fillcolor=lightyellow, label="MemoryBlock\n16KB"];
            MemoryBlock_48K [fillcolor=lightyellow, label="MemoryBlock\n48KB"];
        }
        
        subgraph cluster_rom {
            label="ROM Provider";
            style=filled;
            color=paleturquoise;
            
            ISystemRomProvider [fillcolor=lightgreen, shape=ellipse, label="ISystemRomProvider"];
            SystemRomProvider [fillcolor=lightblue, label="SystemRomProvider\n16KB ROM\nShared", penwidth=3];
        }
        
        subgraph cluster_floating_bus {
            label="Floating Bus";
            style=filled;
            color=paleturquoise;
            
            IFloatingBusProvider [fillcolor=lightgreen, shape=ellipse, label="IFloatingBusProvider"];
            RandomFloatingBusProvider [fillcolor=lightblue, label="RandomFloatingBusProvider"];
        }
        
        // Force memory regions to same rank
        {rank=same; cluster_ram_selector; cluster_slots; cluster_language_card;}
        
        // Force supporting services to same rank
        {rank=same; cluster_system_ram; cluster_rom; cluster_floating_bus;}
    }
    
    // ========================================
    // TIER 5: RENDERING SUBSYSTEM (BOTTOM)
    // ========================================
    
    subgraph cluster_rendering {
        label="Rendering Subsystem";
        style=filled;
        color=mistyrose;
        
        IFrameGenerator [fillcolor=lightgreen, shape=ellipse, label="IFrameGenerator"];
        FrameGenerator [fillcolor=lightblue, label="FrameGenerator"];
        
        IFrameProvider [fillcolor=lightgreen, shape=ellipse, label="IFrameProvider"];
        FrameProvider [fillcolor=lightblue, label="FrameProvider"];
        
        ICharacterRomProvider [fillcolor=lightgreen, shape=ellipse, label="ICharacterRomProvider"];
        CharacterRomProvider [fillcolor=lightblue, label="CharacterRomProvider"];
        
        IDisplayBitmapRenderer [fillcolor=lightgreen, shape=ellipse, label="IDisplayBitmapRenderer"];
        LegacyBitmapRenderer [fillcolor=lightblue, label="LegacyBitmapRenderer"];
        
        VideoMemorySnapshotPool [fillcolor=lightblue, label="VideoMemorySnapshotPool"];
        RenderingService [fillcolor=lightblue, label="RenderingService\nThreaded"];
    }
    
    // ========================================
    // INTERFACE IMPLEMENTATIONS
    // ========================================
    
    CPUAdapter -> ICpu [label="impl", style=dashed, color=blue];
    SingularKeyHandler -> IKeyboardReader [label="impl", style=dashed, color=blue];
    SingularKeyHandler -> IKeyboardSetter [label="impl", style=dashed, color=blue];
    SimpleGameController -> IGameControllerStatus [label="impl", style=dashed, color=blue];
    SystemStatusProvider -> ISystemStatusProvider [label="impl", style=dashed, color=blue];
    SystemStatusProvider -> ISystemStatusMutator [label="impl", style=dashed, color=blue];
    ISystemStatusMutator -> ISystemStatusProvider [label="extends", style=dashed, color=green];
    AddressSpaceController -> IMemory [label="impl", style=dashed, color=blue];
    AddressSpaceController -> IDirectMemoryPoolReader [label="impl", style=dashed, color=blue];
    VA2MBus -> IAppleIIBus [label="impl", style=dashed, color=blue];
    SystemIoHandler -> ISystemIoHandler [label="impl", style=dashed, color=blue];
    Slots -> ISlots [label="impl", style=dashed, color=blue];
    NullCard -> ICard [label="impl", style=dashed, color=blue];
    LanguageCard -> ILanguageCard [label="impl", style=dashed, color=blue];
    SystemRamSelector -> ISystemRamSelector [label="impl", style=dashed, color=blue];
    MemoryBlock_16K -> ISystemRam [label="impl", style=dashed, color=blue];
    MemoryBlock_48K -> ISystemRam [label="impl", style=dashed, color=blue];
    SystemRomProvider -> ISystemRomProvider [label="impl", style=dashed, color=blue];
    RandomFloatingBusProvider -> IFloatingBusProvider [label="impl", style=dashed, color=blue];
    FrameGenerator -> IFrameGenerator [label="impl", style=dashed, color=blue];
    FrameProvider -> IFrameProvider [label="impl", style=dashed, color=blue];
    CharacterRomProvider -> ICharacterRomProvider [label="impl", style=dashed, color=blue];
    LegacyBitmapRenderer -> IDisplayBitmapRenderer [label="impl", style=dashed, color=blue];
    EmulatorStateProvider -> IEmulatorState [label="impl", style=dashed, color=blue];
    
    // ========================================
    // KEY DEPENDENCIES
    // ========================================
    
    // VA2M orchestration
    VA2M -> IEmulatorState [color=red];
    VA2M -> IFrameProvider [color=red];
    VA2M -> ISystemStatusMutator [color=red, penwidth=2];
    VA2M -> IAppleIIBus [color=red, penwidth=2];
    VA2M -> AddressSpaceController [color=red];
    VA2M -> IFrameGenerator [color=red];
    VA2M -> RenderingService [color=red];
    VA2M -> VideoMemorySnapshotPool [color=red];
    VA2M -> IKeyboardSetter [color=red];
    VA2M -> IGameControllerStatus [color=red];
    
    // VA2MBus routing
    VA2MBus -> AddressSpaceController [label="$C090+", color=red, penwidth=2];
    VA2MBus -> ICpu [color=red, penwidth=2];
    VA2MBus -> ISystemIoHandler [label="$C000", color=red, penwidth=2];
    
    // SystemIoHandler
    SystemIoHandler -> SoftSwitches [color=red, penwidth=2];
    SystemIoHandler -> IKeyboardReader [color=red];
    SystemIoHandler -> IGameControllerStatus [color=red];
    
    // CPU wrapping
    CPUAdapter -> CPU [label="wraps", color=purple, penwidth=2];
    
    // AddressSpaceController routing
    AddressSpaceController -> ILanguageCard [label="$D000", color=red, penwidth=3];
    AddressSpaceController -> ISystemRamSelector [label="$0000", color=red, penwidth=3];
    AddressSpaceController -> ISlots [label="$C090", color=red, penwidth=3];
    
    // Slots dependencies
    Slots -> ICardFactory [color=red];
    Slots -> ISystemRomProvider [color=red, penwidth=2];
    Slots -> IFloatingBusProvider [color=red];
    Slots -> ISystemStatusProvider [color=red];
    Slots -> ICard [color=red];
    
    // LanguageCard dependencies
    LanguageCard -> ISystemRam [color=red];
    LanguageCard -> ISystemRomProvider [color=red, penwidth=2];
    LanguageCard -> IFloatingBusProvider [color=red];
    LanguageCard -> ISystemStatusProvider [color=red];
    
    // SystemRamSelector dependencies
    SystemRamSelector -> ISystemRam [color=red];
    SystemRamSelector -> IFloatingBusProvider [color=red];
    SystemRamSelector -> ISystemStatusProvider [color=red];
    
    // FrameGenerator dependencies
    FrameGenerator -> IFrameProvider [color=red];
    FrameGenerator -> IDisplayBitmapRenderer [color=red, penwidth=2];
    FrameGenerator -> IDirectMemoryPoolReader [color=red];
    FrameGenerator -> ISystemStatusProvider [color=red];
    
    // Renderer dependencies
    LegacyBitmapRenderer -> ICharacterRomProvider [color=red, penwidth=2];
    
    // SoftSwitches dependencies
    SoftSwitches -> ISystemStatusMutator [color=red, penwidth=3];
    SoftSwitches -> ISystemStatusProvider [color=red];
    
    // SystemStatusProvider observes GameController
    SystemStatusProvider -> IGameControllerStatus [label="observes", color=red, penwidth=2];
    
    // Rendering Service
    RenderingService -> VideoMemorySnapshotPool [color=red];
    RenderingService -> IFrameGenerator [color=red];
    
    // ROM SHARING (CRITICAL)
    Slots -> SystemRomProvider [label="ROM", color=purple, penwidth=3, style=bold];
    LanguageCard -> SystemRomProvider [label="ROM", color=purple, penwidth=3, style=bold];
}
